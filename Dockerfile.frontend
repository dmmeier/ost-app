# Pin to exact Node.js version to avoid dependency drift
FROM node:22.22.2-alpine

WORKDIR /app

# Copy package files
COPY frontend/package*.json ./

# Install dependencies
RUN npm ci

# Copy frontend code
COPY frontend/ ./

# API URL baked into the Next.js build (override with --build-arg)
ARG NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL

# Build frontend
RUN npm run build

# Expose port
EXPOSE 3000

# Run frontend
CMD ["npm", "start"]
